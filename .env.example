# ============================================================
# Thronos EduPresence — Environment Variables
# Αντέγραψε σε .env και συμπλήρωσε τις τιμές
# ============================================================

# --- Core ---
APP_NAME=Thronos EduPresence
ENVIRONMENT=production

# --- Database ---
# ΣΗΜΑΝΤΙΚΟ: Χρησιμοποίησε absolute path για Railway volume στο /data
DATABASE_URL=sqlite:////data/edupresence_v4.db

# --- URLs ---
PUBLIC_BASE_URL=https://thronosEDu.thronoschain.org

# --- Security ---
TOKEN_SECRET=change-me-use-a-long-random-secret
TOKEN_ISSUER=thronos-edupresence

# --- QR & Links ---
QR_TTL_SECONDS=70
STUDENT_LINK_TTL_HOURS=8

# --- Demo / Auth ---
AUTO_SEED_DEMO=false
AUTH_REQUIRED=true

# --- CORS (για React Native / Expo wallet app) ---
CORS_ORIGINS=https://thronosEDu.thronoschain.org,exp://localhost:8081

# --- Viber Bot API ---
SMS_PROVIDER=viber
VIBER_BOT_TOKEN=your-viber-bot-token-here
VIBER_SENDER_NAME=ThrEDU

# --- SMTP Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@thronoschain.org

# --- L2E Integration (Main Chain) ---
L2E_ENABLED=false
L2E_BASE_URL=https://api.thronoschain.org
L2E_API_KEY=
L2E_TENANT_ID=ministry_edu
L2E_ATTENDANCE_THRESHOLD_PCT=80
