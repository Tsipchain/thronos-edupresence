# ============================================================
# Thronos EduPresence - Environment Variables
# Copy this file to .env for local development.
# In Railway, set these as Environment Variables in the dashboard.
# ============================================================

# --- Application ---
APP_NAME=Thronos EduPresence
ENVIRONMENT=production
PUBLIC_BASE_URL=https://thronosEDu.thronoschain.org

# SECURITY: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SECRET=CHANGE_ME_USE_LONG_RANDOM_SECRET_MIN_32_CHARS
TOKEN_ISSUER=thronos-edupresence

# QR code token lifetime (seconds)
QR_TTL_SECONDS=70
# Student attendance link lifetime (hours)
STUDENT_LINK_TTL_HOURS=8

# Set to false in production after first run
AUTO_SEED_DEMO=false

# --- Database ---
# SQLite (Railway Volume mounted at /app/data)
DATABASE_URL=sqlite:////app/data/edupresence_v4.db
# For PostgreSQL (recommended for multi-instance):
# DATABASE_URL=postgresql://user:password@host:5432/edupresence

# --- CORS (Flutter app / external clients) ---
# Comma-separated list of allowed origins
CORS_ORIGINS=https://thronosEDu.thronoschain.org,https://thronoschain.org

# --- Authentication ---
AUTH_REQUIRED=true
AUTH_PROVIDER=mock
SESSION_TTL_HOURS=12

# Mock user (used when AUTH_PROVIDER=mock)
MOCK_USER_FULL_NAME=ΔΙΑΧΕΙΡΙΣΤΗΣ ΣΥΣΤΗΜΑΤΟΣ
MOCK_USER_TAX_ID=000000000
MOCK_USER_ROLE=teacher

# gov.gr / TaxisNet OAuth (set AUTH_PROVIDER=gov to activate)
GOV_OAUTH_AUTHORIZE_URL=
GOV_OAUTH_TOKEN_URL=
GOV_OAUTH_USERINFO_URL=
GOV_OAUTH_CLIENT_ID=
GOV_OAUTH_CLIENT_SECRET=
GOV_OAUTH_REDIRECT_URI=https://thronosEDu.thronoschain.org/auth/gov/callback

# --- SMS Notifications ---
# Options: mock | twilio | http_get | viber
SMS_PROVIDER=viber
SMS_DRY_RUN=false

# Twilio (if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Generic HTTP GET SMS gateway (if SMS_PROVIDER=http_get)
GENERIC_SMS_URL=
GENERIC_SMS_TOKEN=

# --- Viber Business Messages ---
# Obtain from https://partners.viber.com
VIBER_BOT_TOKEN=
VIBER_SENDER_NAME=ThrEDuPresence
# Viber fallback text for unsupported clients
VIBER_MIN_API_VERSION=1

# --- SMTP Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@thronoschain.org
SMTP_FROM_NAME=Thronos EduPresence

# --- Thronos Chain Attestation ---
THRONOS_ATTEST_URL=
THRONOS_ATTEST_API_KEY=
